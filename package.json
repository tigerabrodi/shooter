{
  "name": "shooter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun run --watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "tsc": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"{shared,client,server,tests}/**/*.{ts,html,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "msw": "^2.7.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
